      link="link5" />
    <child
      link="link11" />
    <axis
      xyz="-1 0 0" />
    <limit
      lower="-0.8"
      upper="0.8"
      effort="10"
      velocity="3.0" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- ============================================ -->
  <!-- Gazebo Plugins                               -->
  <!-- ============================================ -->

  <!-- ros_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
    </plugin>
  </gazebo>

  <!-- Planar move plugin: mecanum base via /cmd_vel -->
  <gazebo>
    <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
      <commandTopic>/cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <odometryRate>20.0</odometryRate>
      <robotBaseFrame>base_link</robotBaseFrame>
    </plugin>
  </gazebo>



  <!-- Ground truth odometry: reads base_link pose directly from Gazebo physics engine.
       Zero noise, zero drift. Used by RTAB-Map instead of wheel odometry.
       Topic: /ground_truth/odom (nav_msgs/Odometry, frame_id=odom, child=base_link) -->
  <gazebo>
    <plugin name="ground_truth_p3d" filename="libgazebo_ros_p3d.so">
      <bodyName>base_link</bodyName>
      <topicName>/ground_truth/odom</topicName>
      <frameName>world</frameName>
      <updateRate>50.0</updateRate>
      <gaussianNoise>0.0</gaussianNoise>
      <publishTf>0</publishTf>
    </plugin>
  </gazebo>

  <gazebo reference="left_front_wheel_link"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>
  <gazebo reference="left_rear_wheel_link"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>
  <gazebo reference="right_front_wheel_link"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>
  <gazebo reference="right_rear_wheel_link"><mu1>0.8</mu1><mu2>0.8</mu2></gazebo>

  <!-- Wheel transmissions (for joint_state_controller TF publishing) -->
  <transmission name="tran_left_front_wheel">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="0.05" friction="0.0"/>
    <joint name="left_front_wheel_joint"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
    <actuator name="motor_left_front_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_left_rear_wheel">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="0.05" friction="0.0"/>
    <joint name="left_rear_wheel_joint"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
    <actuator name="motor_left_rear_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_right_front_wheel">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="0.05" friction="0.0"/>
    <joint name="right_front_wheel_joint"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
    <actuator name="motor_right_front_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_right_rear_wheel">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="0.05" friction="0.0"/>
    <joint name="right_rear_wheel_joint"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
    <actuator name="motor_right_rear_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>

  <!-- ============================================ -->
  <!-- Transmissions (arm joint1-5, hand joint6-11) -->
  <!-- ============================================ -->

  <transmission name="tran_joint1">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="0.0"/>
    <joint name="joint1"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint1"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint2">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="0.0"/>
    <joint name="joint2"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint2"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint3">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="0.0"/>
    <joint name="joint3"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint3"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint4">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="0.0"/>
    <joint name="joint4"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint4"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint5">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="0.0"/>
    <joint name="joint5"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint5"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <!-- 夾爪用 EffortJointInterface — effort controller 施力夾緊，不抖動 -->
  <transmission name="tran_joint6">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint6"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint6"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint7">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint7"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint7"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint8">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint8"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint8"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint9">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint9"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint9"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint10">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint10"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint10"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="tran_joint11">
    <type>transmission_interface/SimpleTransmission</type>
    <dynamics damping="1.0" friction="1.0"/>
    <joint name="joint11"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="motor_joint11"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>

  <!-- Orbbec Astra camera (position from JP515 official URDF, z converted to ground-origin frame) -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.11" />
      <inertia ixx="1.0E-04" ixy="0" ixz="0"
               iyy="1.0E-04" iyz="0" izz="1.0E-04" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://mini_mec_six_arm/meshes/camera_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.4 0.4 0.4 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.165 0.04" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="-0.11427 0.00080 0.556" rpy="0 0.06 0" />
    <parent link="base_link" />
    <child link="camera_link" />
  </joint>

  <!-- Optical frame: standard ROS convention (x-right, y-down, z-forward) -->
  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.570796 0 -1.570796"/>
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
  </joint>

  <!-- Prevent Gazebo from lumping camera_link into base_link -->
  <gazebo reference="camera_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Gazebo: camera_link material + RGB + Depth sensors (Orbbec Astra S specs) -->
  <gazebo reference="camera_link">
    <material>Gazebo/Grey</material>

    <!-- RGB Camera: 63.1° HFOV, 640x480, 30fps -->
    <sensor type="camera" name="astra_rgb">
      <update_rate>30</update_rate>
      <camera name="astra_rgb">
        <horizontal_fov>1.1013</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin name="astra_rgb_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>rgb/image_raw</imageTopicName>
        <cameraInfoTopicName>rgb/camera_info</cameraInfoTopicName>
        <frameName>camera_depth_optical_frame</frameName>
      </plugin>
    </sensor>

    <!-- Depth Camera: 58.4° HFOV, 640x480, 30fps, range 0.3-8m -->
    <sensor type="depth" name="astra_depth">
      <update_rate>30</update_rate>
      <camera name="astra_depth">
        <horizontal_fov>1.0194</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.3</near>
          <far>8.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </camera>
      <plugin name="astra_depth_controller" filename="libgazebo_ros_openni_kinect.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>depth/image_color</imageTopicName>
        <cameraInfoTopicName>depth/camera_info</cameraInfoTopicName>
        <depthImageTopicName>depth/image_raw</depthImageTopicName>
        <depthImageCameraInfoTopicName>depth/camera_info</depthImageCameraInfoTopicName>
        <pointCloudTopicName>depth/points</pointCloudTopicName>
        <frameName>camera_depth_optical_frame</frameName>
        <pointCloudCutoff>0.5</pointCloudCutoff>
        <pointCloudCutoffMax>8.0</pointCloudCutoffMax>
      </plugin>
    </sensor>
  </gazebo>


  <!-- gazebo_grasp_fix: stable grasp plugin (industry standard) -->
  <gazebo>
    <plugin name="gazebo_grasp_fix" filename="libgazebo_grasp_fix.so">
      <arm>
        <arm_name>mini_mec_arm</arm_name>
        <palm_link>link5</palm_link>
        <gripper_link>link6</gripper_link>
        <gripper_link>link7</gripper_link>
        <gripper_link>link8</gripper_link>
        <gripper_link>link9</gripper_link>
        <gripper_link>link10</gripper_link>
        <gripper_link>link11</gripper_link>
      </arm>
      <forces_angle_tolerance>100</forces_angle_tolerance>
      <update_rate>50</update_rate>
      <grip_count_threshold>2</grip_count_threshold>
      <max_grip_count>8</max_grip_count>
      <release_tolerance>0.005</release_tolerance>
      <disable_collisions_on_attach>false</disable_collisions_on_attach>
      <contact_topic>__default_topic__</contact_topic>
    </plugin>
  </gazebo>

  <!-- Wheel friction zeroed to prevent dynamic conflict with libgazebo_ros_planar_move -->
  <gazebo reference="left_front_wheel_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="left_rear_wheel_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="right_front_wheel_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="right_rear_wheel_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- Gripper joints: implicit spring damper to prevent ODE instability on low-inertia links -->
  <gazebo reference="joint6"><implicitSpringDamper>true</implicitSpringDamper></gazebo>
  <gazebo reference="joint7"><implicitSpringDamper>true</implicitSpringDamper></gazebo>
  <gazebo reference="joint8"><implicitSpringDamper>true</implicitSpringDamper></gazebo>
  <gazebo reference="joint9"><implicitSpringDamper>true</implicitSpringDamper></gazebo>
  <gazebo reference="joint10"><implicitSpringDamper>true</implicitSpringDamper></gazebo>
  <gazebo reference="joint11"><implicitSpringDamper>true</implicitSpringDamper></gazebo>

  <!-- Gripper contact/friction properties for physical grasping -->
  <gazebo reference="link6">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="link7">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="link8">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="link9">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="link10">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="link11">
    <mu1>50.0</mu1>
    <mu2>50.0</mu2>
    <kp>50000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
    <selfCollide>false</selfCollide>
  </gazebo>

  <!-- ============================================================ -->
  <!-- Chase Camera：給 VLM 判斷用                                  -->
  <!-- 位置：機器人後上方 0.8m + 後方 0.3m，往前下俯 30°            -->
  <!-- 同時看到車身 + 前方桌面，避免被手臂遮擋                     -->
  <!-- 輸出 topic: /chase_cam/image_raw（5Hz RGB，廣角 80°）        -->
  <!-- ============================================================ -->
  <link name="chase_cam_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1.0E-5" ixy="0" ixz="0"
               iyy="1.0E-5" iyz="0" izz="1.0E-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="chase_cam_dark">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
  </link>

  <joint name="chase_cam_joint" type="fixed">
    <!-- 後退 0.5m + 升高 1.1m + 俯 40°：越過 Orbbec 頭頂、看清車身與前方 -->
    <origin xyz="-0.50 0 1.10" rpy="0 0.70 0"/>
    <parent link="base_link"/>
    <child link="chase_cam_link"/>
  </joint>

  <gazebo reference="chase_cam_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <link name="chase_cam_optical_frame"/>
  <joint name="chase_cam_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    <parent link="chase_cam_link"/>
    <child link="chase_cam_optical_frame"/>
  </joint>

  <gazebo reference="chase_cam_link">
    <sensor type="camera" name="chase_camera">
      <update_rate>5</update_rate>
      <camera>
        <horizontal_fov>1.4</horizontal_fov>
        <image>
          <width>2560</width>
          <height>1440</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
      </camera>
      <plugin name="chase_cam_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>5</updateRate>
        <cameraName>chase_cam</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>chase_cam_optical_frame</frameName>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ============================================================ -->
  <!-- Judge Camera：給 E2 VLM judge 用，固定在車體 base_link 上     -->
  <!-- 位置同 chase_cam：後上方俯視，可看到車身、夾爪與前方目標物     -->
  <!-- 輸出 topic: /judge_camera/rgb/image_raw                      -->
  <!-- ============================================================ -->
  <link name="judge_camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1.0E-5" ixy="0" ixz="0"
               iyy="1.0E-5" iyz="0" izz="1.0E-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="judge_camera_green">
        <color rgba="0.0 0.8 0.2 1"/>
      </material>
    </visual>
  </link>

  <joint name="judge_camera_joint" type="fixed">
    <!-- 左側視角：車左方 0.75m、高 0.55m、略前 0.25m，向右看向車身（yaw=-π/2），俯角 0.35 rad -->
    <origin xyz="0.25 0.75 0.55" rpy="0 0.35 -1.5707963"/>
    <parent link="base_link"/>
    <child link="judge_camera_link"/>
  </joint>

  <gazebo reference="judge_camera_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <link name="judge_camera_optical_frame"/>
  <joint name="judge_camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
    <parent link="judge_camera_link"/>
    <child link="judge_camera_optical_frame"/>
  </joint>

  <gazebo reference="judge_camera_link">
    <sensor type="camera" name="judge_camera">
      <update_rate>5</update_rate>
      <camera>
        <horizontal_fov>1.4</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>20.0</far>
        </clip>
      </camera>
      <plugin name="judge_camera_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>5</updateRate>
        <cameraName>judge_camera</cameraName>
        <imageTopicName>rgb/image_raw</imageTopicName>
        <cameraInfoTopicName>rgb/camera_info</cameraInfoTopicName>
        <frameName>judge_camera_optical_frame</frameName>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

</robot>
